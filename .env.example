# Required for live Alpha Vantage ingestion.
# Get a free API key from https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Required for Snowflake warehouse execution.
# Account should be the account identifier without snowflakecomputing.com.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=NASDAQ_ELT_ROLE
SNOWFLAKE_WAREHOUSE=NASDAQ_ELT_WH
SNOWFLAKE_DATABASE=NASDAQ_MARKET_DATA

# Keep the default low enough for Alpha Vantage free-tier limits.
NASDAQ_SYMBOL_LIMIT=25

# Inclusive lower bound for loaded trading dates.
LOAD_START_DATE=2024-01-01

# Optional tuning.
ALPHA_VANTAGE_OUTPUTSIZE=compact
ALPHA_VANTAGE_API_PAUSE_SECONDS=12.5
ALPHA_VANTAGE_TIMEOUT_SECONDS=30
